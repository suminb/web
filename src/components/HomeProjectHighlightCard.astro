---
import {
  featuredYearDatetime,
  formatFeaturedYear,
  type FeaturedYear,
} from "../data/homeProjects";

interface Props {
  title: string;
  description: string;
  tags: string[];
  /** Resolved link target; empty or "#" keeps the title non-clickable. */
  url: string;
  cta: string;
  year?: FeaturedYear;
  workplace?: string;
  cardClass?: string;
  /** When provided, each tag becomes a link: `{tagPageUrl}?tag={tag}` */
  tagPageUrl?: string;
}

const {
  title,
  description,
  tags,
  url,
  cta,
  year,
  workplace,
  cardClass,
  tagPageUrl,
} = Astro.props;

/** `experience_slug` in YAML is already resolved to `url`; "#" is a deliberate non-link. */
const urlTrimmed = url.trim();
const titleIsLink = urlTrimmed !== "" && urlTrimmed !== "#";
const titleLinkExternal = /^https?:\/\//i.test(urlTrimmed);
---

<article class:list={["project-card", cardClass]} data-tags={JSON.stringify(tags)}>
  {year != null || workplace ? (
    <div class="project-card__meta project-card__meta--compact">
      {year != null ? (
        <time datetime={featuredYearDatetime(year)}>
          {formatFeaturedYear(year)}
        </time>
      ) : null}
      {year != null && workplace ? (
        <span class="project-card__meta-sep" aria-hidden="true">·</span>
      ) : null}
      {workplace ? (
        <span class="project-card__workplace">{workplace}</span>
      ) : null}
    </div>
  ) : null}
  <h3>
    {
      titleIsLink ? (
        <a
          class="project-card__heading-link"
          href={urlTrimmed}
          rel={titleLinkExternal ? "noopener noreferrer" : undefined}
        >
          {title}
        </a>
      ) : (
        title
      )
    }
  </h3>
  {description.trim() ? <p>{description}</p> : null}
  <div class="tag-row">
    {tags.map((t) =>
      tagPageUrl ? (
        <a class="tag tag--link" href={`${tagPageUrl}?tag=${encodeURIComponent(t)}`}>{t}</a>
      ) : (
        <span class="tag">{t}</span>
      )
    )}
  </div>
  {titleIsLink && cta.trim() ? (
    <a class="project-card__cta" href={urlTrimmed}>
      {cta} →
    </a>
  ) : null}
</article>
