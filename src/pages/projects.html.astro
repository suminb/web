---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import { site, featuredProjects, moreProjects } from "../data/site";
import { formatFeaturedYear, type FeaturedYear } from "../data/homeProjects";
import {
  archiveProjectTags,
  formatArchiveYear,
  sortedArchiveProjects,
} from "../data/archiveProjects";

type ProjectRow = {
  title: string;
  href?: string;
  description?: string;
  tags: string[];
  year?: string;
};

function fmtYear(y: FeaturedYear | undefined): string | undefined {
  return y !== undefined ? formatFeaturedYear(y) : undefined;
}

const allProjects: ProjectRow[] = [
  ...featuredProjects.map((p) => ({
    title: p.title,
    href: p.href,
    description: p.description || undefined,
    tags: [...p.tags],
    year: fmtYear(p.year),
  })),
  ...moreProjects.map((p) => ({
    title: p.title,
    href: p.href,
    description: p.description || undefined,
    tags: [...p.tags],
    year: fmtYear(p.year),
  })),
  ...sortedArchiveProjects().map((p) => ({
    title: p.name,
    href: p.url || undefined,
    description: undefined,
    tags: archiveProjectTags(p),
    year: formatArchiveYear(p.year),
  })),
];

const pageTitle = `Projects · ${site.title}`;
---

<BaseLayout title={pageTitle} description="All projects — featured, previous, and archive.">
  <header class="wrap site-header">
    <SiteNav />
  </header>
  <main id="main">
    <div class="wrap experience-main">
      <h1 class="experience-title">Projects</h1>
    </div>
    <section class="wrap section">
      <div id="tag-filter-bar" class="tag-filter-bar" hidden>
        <span class="tag-filter-bar__label">Tag:</span>
        <span class="tag tag--active" id="tag-filter-label"></span>
        <a href="/projects.html" class="tag-filter-clear">× clear</a>
      </div>
      <div class="project-grid">
        {
          allProjects.map((p) => (
            <article class="project-card project-card--archive" data-tags={JSON.stringify(p.tags)}>
              {p.year ? (
                <div class="project-card__meta">
                  <time>{p.year}</time>
                </div>
              ) : null}
              <h3 class="project-card__title">
                {p.href ? (
                  <a href={p.href}>{p.title}</a>
                ) : (
                  p.title
                )}
              </h3>
              {p.description ? <p>{p.description}</p> : null}
              {p.tags.length > 0 ? (
                <div class="tag-row">
                  {p.tags.map((t) => (
                    <a class="tag tag--dim tag--link" href={`/projects.html?tag=${encodeURIComponent(t)}`}>{t}</a>
                  ))}
                </div>
              ) : null}
            </article>
          ))
        }
      </div>
    </section>
  </main>
  <SiteFooter />
  <script is:inline>
    (function () {
      var params = new URLSearchParams(location.search);
      var activeTag = params.get("tag");
      if (!activeTag) return;

      // Show filter banner
      var bar = document.getElementById("tag-filter-bar");
      var label = document.getElementById("tag-filter-label");
      if (bar) bar.hidden = false;
      if (label) label.textContent = activeTag;

      // Hide items whose tags don't include the active tag
      document.querySelectorAll("[data-tags]").forEach(function (el) {
        var tags;
        try { tags = JSON.parse(el.getAttribute("data-tags")); } catch (e) { tags = []; }
        var matches = tags.some(function (t) {
          return t.toLowerCase() === activeTag.toLowerCase();
        });
        if (!matches) el.hidden = true;
      });
    })();
  </script>
</BaseLayout>
